# OAuth Configuration for Google and Apple Sign-In
# Replace the empty values below with your actual credentials

# Google OAuth Credentials
# Get these from: https://console.developers.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple Sign-In Credentials
# Get these from: https://developer.apple.com/account/resources/authkeys/list
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Frontend OAuth Redirect URL
# This should match where your oauth-callback.html page is hosted
FRONTEND_OAUTH_REDIRECT=http://127.0.0.1:5500/oauth-callback.html